{
  "permissions": {
    "allow": [
      "Bash(.venv/Scripts/python.exe:*)",
      "Bash(env FLASK_DEBUG=0 FLASK_USE_RELOADER=0 .venv/Scripts/python.exe app.py)",
      "Bash(npx playwright:*)",
      "Bash(npm run build:css)",
      "Bash(npm run watch:css)",
      "Bash(npm install)",
      "Bash(python -m pytest *)",
      "Bash(python app.py)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(gh repo view *)",
      "Bash(gh issue view *)",
      "Bash(gh pr view *)",
      "Skill(requirements)",
      "Skill(council-plan)",
      "Skill(run-tests)",
      "Skill(run-e2e)",
      "Skill(verify-suite)",
      "Skill(verify-and-polish)",
      "Skill(verify)",
      "Skill(run)",
      "Skill(build-css)",
      "Skill(run-hypertrophy-toolbox)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__playwright__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["context7", "puppeteer"]
}
