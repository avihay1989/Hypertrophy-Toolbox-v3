{
  "permissions": {
    "allow": [
      "Bash(.venv/Scripts/python.exe:*)",
      "Bash(npx playwright:*)",
      "Bash(npm run build:css)",
      "Bash(npm run watch:css)",
      "Bash(npm install)",
      "Bash(python -m pytest *)",
      "Bash(python app.py)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(gh repo view *)",
      "Bash(gh issue view *)",
      "Bash(gh pr view *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["context7", "puppeteer"]
}
